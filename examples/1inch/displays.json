            {"key": "desc_recipient", "value": "The wallet address that will receive the swapped tokens"},
            {"key": "desc_swap_options", "value": "Additional swap execution settings"},
            {"key": "desc_partial_fill", "value": "If enabled, the swap can be partially filled if the full amount cannot be executed"}
