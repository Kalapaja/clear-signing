{
  "$schema": "../../schemas/display.schema.json",
  "displays": [
    {
      "abi": "function swap(address executor, (address srcToken, address dstToken, address srcReceiver, address dstReceiver, uint256 amount, uint256 minReturnAmount, uint256 flags) desc, bytes data)",
      "title": "$labels.swap_title",
      "description": "$labels.swap_description",
      "fields": [
        {
          "title": "$labels.you_send",
          "description": "$labels.desc_you_send",
          "format": "tokenAmount",
          "params": [
            {"key": "token", "value": "$data.desc.srcToken"},
            {"key": "amount", "value": "$data.desc.amount"},
            {"key": "direction", "value": "out"}
          ]
        },
        {
          "title": "$labels.you_receive_minimum",
          "description": "$labels.desc_you_receive_minimum",
          "format": "tokenAmount",
          "params": [
            {"key": "token", "value": "$data.desc.dstToken"},
            {"key": "amount", "value": "$data.desc.minReturnAmount"},
            {"key": "direction", "value": "in"}
          ]
        },
        {
          "title": "$labels.recipient",
          "description": "$labels.desc_recipient",
          "format": "address",
          "params": [{"key": "value", "value": "$data.desc.dstReceiver"}]
        },
        {
          "title": "$labels.swap_options",
          "description": "$labels.desc_swap_options",
          "format": "bitmask",
          "params": [
            {"key": "value", "value": "$data.desc.flags"},
            {"key": "#0", "value": "$labels.partial_fill_enabled"}
          ]
        }
      ],
      "labels": [
        {
          "locale": "en",
          "items": [
            {"key": "swap_title", "value": "1inch Swap"},
            {"key": "swap_description", "value": "Exchange one token for another using the 1inch aggregation protocol"},
            {"key": "you_send", "value": "You Send"},
            {"key": "you_receive_minimum", "value": "You Receive (Minimum)"},
            {"key": "recipient", "value": "Recipient"},
            {"key": "swap_options", "value": "Swap Options"},
            {"key": "partial_fill_enabled", "value": "Partial fill allowed"},
            {"key": "desc_you_send", "value": "The exact amount you will send from your wallet"},
            {"key": "desc_you_receive_minimum", "value": "The minimum amount you will receive. You may receive more if the exchange rate improves"},
            {"key": "desc_recipient", "value": "The wallet address that will receive the swapped tokens"},
            {"key": "desc_swap_options", "value": "Additional swap execution settings"},
            {"key": "desc_partial_fill", "value": "If enabled, the swap can be partially filled if the full amount cannot be executed"}
          ]
        },
        {
          "locale": "es",
