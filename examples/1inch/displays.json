        {
          "locale": "ru",
          "items": [
            {"key": "swap_title", "value": "\u041e\u0431\u043c\u0435\u043d 1inch"},
            {"key": "swap_description", "value": "\u041e\u0431\u043c\u0435\u043d\u044f\u0439\u0442\u0435 \u043e\u0434\u0438\u043d \u0442\u043e\u043a\u0435\u043d \u043d\u0430 \u0434\u0440\u0443\u0433\u043e\u0439, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044f \u043f\u0440\u043e\u0442\u043e\u043a\u043e\u043b \u0430\u0433\u0440\u0435\u0433\u0430\u0446\u0438\u0438 1inch"},
            {"key": "you_send", "value": "\u0412\u044b \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442\u0435"},
            {"key": "you_receive_minimum", "value": "\u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0442\u0435 (\u041c\u0438\u043d\u0438\u043c\u0443\u043c)"},
            {"key": "recipient", "value": "\u041f\u043e\u043b\u0443\u0447\u0430\u0442\u0435\u043b\u044c"},
