{
  "$schema": "../../schemas/display.schema.json",
  "displays": [
    {
      "title": "Swap",
      "abi": "function execute(bytes commands, bytes[] inputs, uint256 deadline) payable",
      "fields": [
        {
          "title": "Account",
          "format": "address",
          "params": [{"key": "value", "value": "$msg.sender"}]
        },
        {
          "format": "array",
          "params": [
            {"key": "$command", "value": "$data.commands"},
            {"key": "$input", "value": "$data.inputs"}
          ],
          "fields": [
            {
              "format": "switch",
              "params": [{"key": "value", "value": "$data.command"}],
              "fields": [
                {
                  "description": "V2 SWAP EXACT IN",
                  "format": "match",
                  "case": ["0x08"],
                  "params": [
                    {"key": "value", "value": "$data.input"},
                    {
                      "key": "abi",
                      "value": "(address recipient, uint256 amountIn, uint256 amountOutMin, address[] path, bool payerIsUser)"
                    }
                  ],
                  "fields": [
                    {
                      "format": "switch",
                      "params": [{"key": "value", "value": "$data.payerIsUser"}],
                      "fields": [
                        {
                          "title": "Send",
                          "format": "tokenAmount",
                          "case": ["true"],
                          "params": [
                            {"key": "token", "value": "$data.path[0]"},
                            {"key": "amount", "value": "$data.amountIn"},
                            {"key": "direction", "value": "out"}
                          ]
                        }
                      ]
                    },
                    {
                      "format": "switch",
                      "params": [{"key": "value", "value": "$data.recipient"}],
                      "fields": [
                        {
                          "title": "Receive minimum",
                          "format": "tokenAmount",
                          "case": ["$msg.sender", "0x0000000000000000000000000000000000000001"],
                          "params": [
                            {"key": "token", "value": "$data.path[-1]"},
                            {"key": "amount", "value": "$data.amountOutMin"},
                            {"key": "direction", "value": "in"}
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "description": "V2 SWAP EXACT OUT",
                  "format": "match",
                  "case": ["0x09"],
                  "params": [
                    {"key": "value", "value": "$data.input"},
                    {
                      "key": "abi",
                      "value": "(address recipient, uint256 amountOut, uint256 amountInMax, address[] path, bool payerIsUser)"
                    }
                  ],
                  "fields": [
                    {
                      "format": "switch",
                      "params": [{"key": "value", "value": "$data.payerIsUser"}],
                      "fields": [
                        {
                          "title": "Send maximum",
                          "format": "tokenAmount",
                          "case": ["true"],
                          "params": [
                            {"key": "token", "value": "$data.path[0]"},
                            {"key": "amount", "value": "$data.amountInMax"},
                            {"key": "direction", "value": "out"}
                          ]
                        }
                      ]
                    },
                    {
                      "format": "switch",
                      "params": [{"key": "value", "value": "$data.recipient"}],
                      "fields": [
                        {
                          "title": "Receive",
                          "format": "tokenAmount",
                          "case": ["$msg.sender", "0x0000000000000000000000000000000000000001"],
                          "params": [
                            {"key": "token", "value": "$data.path[-1]"},
                            {"key": "amount", "value": "$data.amountOut"},
                            {"key": "direction", "value": "in"}
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "description": "V3 SWAP EXACT IN",
                  "format": "match",
                  "case": ["0x00"],
                  "params": [
                    {"key": "value", "value": "$data.input"},
                    {
                      "key": "abi",
                      "value": "(address recipient, uint256 amountIn, uint256 amountOutMin, bytes pathBytes, bool payerIsUser)"
                    }
                  ],
                  "fields": [
                    {
                      "format": "switch",
                      "params": [{"key": "value", "value": "$data.payerIsUser"}],
                      "fields": [
                        {
                          "title": "Send",
                          "format": "tokenAmount",
                          "case": ["true"],
                          "params": [
                            {"key": "token", "value": "$data.pathBytes[:20]"},
                            {"key": "amount", "value": "$data.amountIn"},
                            {"key": "direction", "value": "out"}
                          ]
                        }
                      ]
                    },
                    {
                      "format": "switch",
                      "params": [{"key": "value", "value": "$data.recipient"}],
                      "fields": [
                        {
                          "title": "Receive minimum",
                          "format": "tokenAmount",
                          "case": ["$msg.sender", "0x0000000000000000000000000000000000000001"],
                          "params": [
                            {"key": "token", "value": "$data.pathBytes[-20:]"},
                            {"key": "amount", "value": "$data.amountOutMin"},
                            {"key": "direction", "value": "in"}
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "description": "V3 SWAP EXACT OUT",
                  "format": "match",
                  "case": ["0x01"],
                  "params": [
                    {
                      "key": "value",
                      "value": "$data.input"
                    },
                    {
                      "key": "abi",
                      "value": "(address recipient, uint256 amountOut, uint256 amountInMax, bytes pathBytes, bool payerIsUser)"
                    }
                  ],
                  "fields": [
                    {
                      "format": "switch",
                      "params": [
                        {
                          "key": "value",
                          "value": "$data.payerIsUser"
                        }
                      ],
                      "fields": [
                        {
                          "title": "Send maximum",
                          "format": "tokenAmount",
                          "case": ["true"],
                          "params": [
                            {"key": "token", "value": "$data.pathBytes[:20]"},
                            {"key": "amount", "value": "$data.amountInMax"},
                            {"key": "direction", "value": "out"}
                          ]
                        }
                      ]
                    },
                    {
                      "format": "switch",
                      "params": [{"key": "value", "value": "$data.recipient"}],
                      "fields": [
                        {
                          "title": "Receive",
                          "format": "tokenAmount",
                          "case": ["$msg.sender", "0x0000000000000000000000000000000000000001"],
                          "params": [
                            {"key": "token", "value": "$data.pathBytes[-20:]"},
                            {"key": "amount", "value": "$data.amountOut"},
                            {"key": "direction", "value": "in"}
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "description": "Unwrap ETH",
                  "format": "match",
                  "case": ["0x0c"],
                  "params": [
                    {"key": "value", "value": "$data.input"},
                    {"key": "abi", "value": "(address recipient, uint256 amountOutMin)"}
                  ],
                  "fields": [
                    {
                      "format": "switch",
                      "params": [{"key": "value", "value": "$data.recipient"}],
                      "fields": [
                        {
                          "title": "Receive minimum",
                          "format": "tokenAmount",
                          "case": ["$msg.sender"],
                          "params": [
                            {"key": "token", "value": "0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2"},
                            {"key": "amount", "value": "$data.amountOutMin"},
                            {"key": "direction", "value": "in"}
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "description": "Wrap ETH",
                  "format": "match",
                  "case": ["0x0b"],
                  "params": [
                    {"key": "value", "value": "$data.input"},
                    {"key": "abi", "value": "(address recipient, uint256 amountIn)"}
                  ],
                  "fields": [
                    {
                      "title": "Send",
                      "format": "tokenAmount",
                      "params": [
                        {"key": "token", "value": "0xeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee"},
                        {"key": "amount", "value": "$data.amountIn"},
                        {"key": "direction", "value": "out"}
                      ]
                    }
                  ]
                },
                {
                  "description": "Execute Sub Plan",
                  "format": "match",
                  "case": ["0x21"],
                  "params": [
                    {"key": "value", "value": "$data.input"},
                    {"key": "abi", "value": "(bytes commands, bytes[] inputs)"}
                  ],
                  "fields": [
                    {
                      "format": "array",
                      "params": [
                        {"key": "$command", "value": "$data.commands"},
                        {"key": "$input", "value": "$data.inputs"}
                      ],
                      "fields": []
                    }
                  ]
                },
                {
                  "description": "V4 Swap",
                  "format": "match",
                  "case": ["0x10"],
                  "params": [
                    {"key": "value", "value": "$data.input"},
                    {"key": "abi", "value": "(bytes actions, bytes[] params)"}
                  ],
                  "fields": [
                    {
                      "format": "array",
                      "params": [
                        {"key": "$action", "value": "$data.actions"},
                        {"key": "$param", "value": "$data.params"}
                      ],
                      "fields": [
                        {
                          "format": "switch",
                          "params": [{"key": "value", "value": "$data.action"}],
                          "fields": [
                            {
                              "description": "V4 SWAP EXACT IN",
                              "format": "match",
                              "case": ["0x07"],
                              "params": [
                                {"key": "value", "value": "$data.param"},
                                {
                                  "key": "abi",
                                  "value": "((address tokenIn, (address token, uint24, int24, address, bytes)[] pathKeys, uint256 amountIn, uint256 amountOutMin) swap)"
                                }
                              ],
                              "fields": [
                                {
                                  "title": "Send",
                                  "format": "tokenAmount",
                                  "params": [
                                    {"key": "token", "value": "$data.swap.tokenIn"},
                                    {"key": "amount", "value": "$data.swap.amountIn"},
                                    {"key": "direction", "value": "out"}
                                  ]
                                },
                                {
                                  "title": "Receive minimum",
                                  "format": "tokenAmount",
                                  "params": [
                                    {"key": "token", "value": "$data.swap.pathKeys[-1].token"},
                                    {"key": "amount", "value": "$data.swap.amountOutMin"},
                                    {"key": "direction", "value": "in"}
                                  ]
                                }
                              ]
                            },
                            {
                              "description": "V4 SWAP EXACT IN SINGLE",
                              "format": "match",
                              "case": ["0x06"],
                              "params": [
                                {"key": "value", "value": "$data.param"},
                                {
                                  "key": "abi",
                                  "value": "(((address token0, address token1, uint24, int24, address) pool, bool zeroForOne, uint256 amountIn, uint256 amountOutMin, bytes) swap)"
                                }
                              ],
                              "fields": [
                                {
                                  "format": "switch",
                                  "params": [{"key": "value", "value": "$data.swap.zeroForOne"}],
                                  "fields": [
                                    {
                                      "title": "Send",
                                      "format": "tokenAmount",
                                      "case": ["true"],
                                      "params": [
                                        {"key": "token", "value": "$data.swap.pool.token0"},
                                        {"key": "amount", "value": "$data.swap.amountIn"},
                                        {"key": "direction", "value": "out"}
                                      ]
                                    },
                                    {
                                      "title": "Receive minimum",
                                      "format": "tokenAmount",
                                      "case": ["true"],
                                      "params": [
                                        {"key": "token", "value": "$data.swap.pool.token1"},
                                        {"key": "amount", "value": "$data.swap.amountOutMin"},
                                        {"key": "direction", "value": "in"}
                                      ]
                                    },
                                    {
                                      "title": "Send",
                                      "format": "tokenAmount",
                                      "case": ["false"],
                                      "params": [
                                        {"key": "token", "value": "$data.swap.pool.token1"},
                                        {"key": "amount", "value": "$data.swap.amountIn"},
                                        {"key": "direction", "value": "out"}
                                      ]
                                    },
                                    {
                                      "title": "Receive minimum",
                                      "format": "tokenAmount",
                                      "case": ["false"],
                                      "params": [
                                        {"key": "token", "value": "$data.swap.pool.token0"},
                                        {"key": "amount", "value": "$data.swap.amountOutMin"},
                                        {"key": "direction", "value": "in"}
                                      ]
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "description": "V4 SWAP EXACT OUT",
                              "format": "match",
                              "case": ["0x09"],
                              "params": [
                                {"key": "value", "value": "$data.param"},
                                {
                                  "key": "abi",
                                  "value": "((address tokenOut, (address token, uint24, int24, address, bytes)[] pathKeys, uint256 amountOut, uint256 amountInMax) swap)"
                                }
                              ],
                              "fields": [
                                {
                                  "title": "Send maximum",
                                  "format": "tokenAmount",
                                  "params": [
                                    {"key": "token", "value": "$data.swap.tokenIn"},
                                    {"key": "amount", "value": "$data.swap.amountInMax"},
                                    {"key": "direction", "value": "out"}
                                  ]
                                },
                                {
                                  "title": "Receive",
                                  "format": "tokenAmount",
                                  "params": [
                                    {"key": "token", "value": "$data.swap.pathKeys[-1].token"},
                                    {"key": "amount", "value": "$data.swap.amountOut"},
                                    {"key": "direction", "value": "in"}
                                  ]
                                }
                              ]
                            },
                            {
                              "description": "V4 SWAP EXACT OUT SINGLE",
                              "format": "match",
                              "case": ["0x08"],
                              "params": [
                                {"key": "value", "value": "$data.param"},
                                {
                                  "key": "abi",
                                  "value": "(((address token0, address token1, uint24, int24, address) pool, bool zeroForOne, uint256 amountOut, uint256 amountInMax, bytes) swap)"
                                }
                              ],
                              "fields": [
                                {
                                  "format": "switch",
                                  "params": [{"key": "value", "value": "$data.swap.zeroForOne"}],
                                  "fields": [
                                    {
                                      "title": "Send maximum",
                                      "format": "tokenAmount",
                                      "case": ["true"],
                                      "params": [
                                        {"key": "token", "value": "$data.swap.pool.token0"},
                                        {"key": "amount", "value": "$data.swap.amountInMax"},
                                        {"key": "direction", "value": "out"}
                                      ]
                                    },
                                    {
                                      "title": "Receive",
                                      "format": "tokenAmount",
                                      "case": ["true"],
                                      "params": [
                                        {"key": "token", "value": "$data.swap.pool.token1"},
                                        {"key": "amount", "value": "$data.swap.amountOut"},
                                        {"key": "direction", "value": "in"}
                                      ]
                                    },
                                    {
                                      "title": "Send maximum",
                                      "format": "tokenAmount",
                                      "case": ["false"],
                                      "params": [
                                        {"key": "token", "value": "$data.swap.pool.token1"},
                                        {"key": "amount", "value": "$data.swap.amountInMax"},
                                        {"key": "direction", "value": "out"}
                                      ]
                                    },
                                    {
                                      "title": "Receive",
                                      "format": "tokenAmount",
                                      "case": ["false"],
                                      "params": [
                                        {"key": "token", "value": "$data.swap.pool.token0"},
                                        {"key": "amount", "value": "$data.swap.amountOut"},
                                        {"key": "direction", "value": "in"}
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Deadline",
          "format": "datetime",
          "params": [{"key": "value", "value": "$data.deadline"}]
        }
      ],
      "labels": [
        {
          "locale": "en",
          "items": []
        }
      ]
    }
  ]
}
