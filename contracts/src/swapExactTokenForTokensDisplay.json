{
  "displays": [
    {
      "abi": "function swapExactTokensForTokens(uint256 amountIn, uint256 amountOutMin, address[] path, address to, uint256 deadline)",
      "title": "$labels.swap",
      "description": "$labels.swap_description",
      "fields": [
        {
          "title": "$labels.sending",
          "description": "$labels.sending_description",
          "format": "tokenAmount",
          "params": [
            {
              "key": "token",
              "value": "$locals.path[0]"
            },
            {
              "key": "amount",
              "value": "$locals.amountIn"
            }
          ]
        },
        {
          "title": "$labels.receiving_min",
          "description": "$labels.receiving_min_description",
          "format": "tokenAmount",
          "params": [
            {
              "key": "token",
              "value": "$locals.path[-1]"
            },
            {
              "key": "amount",
              "value": "$locals.amountOutMin"
            }
          ]
        },
        {
          "title": "$labels.recipient",
          "description": "$labels.recipient_description",
          "format": "address",
          "params": [
            {
              "key": "value",
              "value": "$locals.to"
            }
          ]
        },
        {
          "title": "$labels.deadline",
          "description": "$labels.deadline_description",
          "format": "datetime",
          "params": [
            {
              "key": "value",
              "value": "$locals.deadline"
            }
          ]
        }
      ],
      "labels": [
        {
          "locale": "en",
          "items": [
            {
              "key": "swap",
              "value": "Swap Tokens"
            },
            {
              "key": "swap_description",
              "value": "Exchange one token for another at the current market rate"
            },
            {
              "key": "sending",
              "value": "You're Sending"
            },
            {
              "key": "sending_description",
              "value": "Exact amount of tokens you're swapping"
            },
            {
              "key": "receiving_min",
              "value": "You're Receiving (minimum)"
            },
            {
              "key": "receiving_min_description",
              "value": "Minimum amount you'll receive - protects against price slippage"
            },
            {
              "key": "recipient",
              "value": "Recipient"
            },
            {
              "key": "recipient_description",
              "value": "Address that will receive the output tokens"
            },
            {
              "key": "deadline",
              "value": "Deadline"
            },
            {
              "key": "deadline_description",
              "value": "Transaction must complete before this time"
            }
          ]
        }
      ]
    }
  ]
}